[providers.xai]
api_key = "xai-your-api-key-here"

# Hosted subscription — one key, no provider accounts. See relay/README.md.
# No setup: run `voice-keyboard login <your email>` and this fills itself in
# (emails you a code, writes the key, switches stt/tts here). Lose the key or
# move machines? Just log in again — there's nothing to save by hand.
[providers.hyperfurion]
api_key = "hfk-your-subscription-key-here"
# Only set base_url if you run your own relay.
# base_url = "https://api.hyperfurion.com"

[providers.openai]
api_key = "openai-your-api-key-here"
# Any OpenAI-compatible server works — a local one (Speaches, whisper.cpp,
# vLLM) makes dictation fully offline, and needs no api_key.
# base_url = "http://localhost:8000/v1"

[providers.groq]
api_key = "groq-your-api-key-here"

[providers.deepgram]
api_key = "deepgram-your-api-key-here"

[providers.assemblyai]
api_key = "assemblyai-your-api-key-here"

[providers.elevenlabs]
api_key = "elevenlabs-your-api-key-here"

[stt]
# Choices: xai, hyperfurion, openai, groq, deepgram, assemblyai
provider = "xai"
# Defaults by provider:
# openai = "gpt-4o-transcribe"
# groq = "whisper-large-v3-turbo"
# deepgram = "nova-3"
# assemblyai = provider default
model = ""
language = "en"
interim_results = true
# Bias recognition toward the hotwords you accepted via
# `voice-keyboard learned` — curated vocabulary you actually say. REST
# providers only (openai prompt / deepgram keyterm / assemblyai
# word_boost); assembled per session, never stored. Password fields are
# always excluded. Screen text is never harvested.
hotword_bias = false

[tts]
# Choices: xai, hyperfurion, openai, elevenlabs
provider = "xai"
# Defaults by provider:
# openai = "gpt-4o-mini-tts"
# elevenlabs = "eleven_multilingual_v2"
model = ""
# Defaults by provider:
# xai = "eve"
# openai = "coral"
# elevenlabs = "JBFqnCBsd6RMkjVDRZzb"
voice_id = "eve"
language = "en"
# Speculative TTS: synthesize the primary selection while you highlight,
# so `voice-keyboard tts` plays instantly. "auto" = only against a LOCAL
# openai-compatible endpoint (free); "always" opts in cloud TTS (spends
# tokens on selections never played, and sends selection text before you
# ask); "off" = never.
prefetch = "off"

[audio]
sample_rate = 16000
chunk_ms = 100
device_name = "default"

[hotkey]
enabled = true
key = "control+alt+v"
# "auto" = tap to toggle, or hold to record until release.
# You can still force "toggle" or "hold" if you want only one gesture.
mode = "auto"
# How long a press counts as a hold in "auto" mode.
hold_threshold_ms = 280

# ── Flow: molten dictation ────────────────────────────────────────────
# Edits to [flow], [registers], [llm], [intent], and [ambient] hot-reload
# at the next recording — no daemon restart needed.

[flow]
# The grammar + register pipeline (all providers). false = the daemon
# behaves exactly as it did before Flow existed.
enabled = true
# Type words live while you speak, repairing in place as the transcript
# firms up (streaming providers: xai, hyperfurion, live_rest).
live = true
# Spoken commands and punctuation: "scratch that", "new line", "period",
# "literal <word>", ...
grammar = true
# A molten word freezes after surviving this long and this many updates.
# Until it freezes, provider revisions repair it on screen.
stability_ms = 1500
stability_updates = 2
# Upper bound on the revisable tail; repairs can never be longer.
max_molten_chars = 160
# Widen the horizon automatically when the provider revises deeply.
adaptive = true
# Molten dictation for buffered REST providers by re-transcribing the
# growing recording on an interval. "auto" enables it only against a
# LOCAL openai-compatible base_url (re-transcribing is free there);
# "always" opts in cloud REST providers too (each probe re-bills!).
live_rest = "auto"
live_rest_interval_ms = 2500
# Stop recording automatically after this much silence (0 = off).
# 1200 is a good hands-free value.
auto_stop_ms = 0
# Spoken cardinals -> digits ("twenty three" -> 23).
# "auto" = terminal register only, "always", or "off".
numbers = "auto"
# Opt-in local dictation ledger for `voice-keyboard history` / `recall`.
# Entries: ~/.local/state/voice-keyboard/history.jsonl (mode 600).
history = false
# Merge corrections you accepted via `voice-keyboard learned` into the
# grammar vocabulary. Dormant until you accept something; your explicit
# [flow.vocabulary] entries always win.
personal_dictionary = true
# Molten diffs: hold a "vk, ..." rewrite as PENDING instead of
# landing it — say "keep it" (or `voice-keyboard keep`) to apply,
# "scratch that" (or `discard`) to drop; unkept rewrites evaporate
# after two minutes. false = rewrites land immediately, as before.
rewrite_pending = false
# Say "<wake_word>, <instruction>" at the end of an utterance to rewrite
# it through [llm]: "... vk, make that formal".
wake_word = "vk"

[flow.vocabulary]
# Spoken phrase -> replacement (multi-word keys fine).
# "hyper furion" = "HyperFurion"

[flow.commands]
# Remap command phrases. Actions: scratch_that, new_line, new_paragraph,
# literal. Values may be a string or a list of strings.
# scratch_that = ["nuke it", "scratch that"]

[flow.punctuation]
# Remap spoken punctuation; "" removes a phrase.
# "period" = "."
# "comma" = ""

[registers]
# How dictation renders per app: prose (smart caps + punctuation),
# terminal (verbatim-ish, numbers as digits, ctrl+shift+v paste),
# verbatim (grammar off), python / shell (semantic registers that COMPILE
# speech: "for i in range ten colon" -> `for i in range(10):`,
# "pipe grep dash i error" -> `| grep -i error`).
# Password fields always force verbatim and are never remembered.
default = "prose"
# Probe the focused app at recording start (AT-SPI on Linux, Quartz on
# macOS, Win32 on Windows) to pick the register automatically.
probe = true

[registers.map]
# App -> register overrides, merged over the built-in terminal list.
# kitty = "terminal"
# code = "verbatim"

[llm]
# The interactive brain: "vk, ..." rewrites, `voice-keyboard
# transform`, intent command compilation, and Kai's terminal
# command-vs-question routing. Fully model-agnostic — ANY
# OpenAI-compatible /chat/completions endpoint works.
#
# Cloud default (needs a key):
provider = "xai"
base_url = ""
api_key = ""
model = "grok-4.3"
#
# LOCAL / offline (no key, private, bundle-friendly) — point at a local
# OpenAI-compatible server. Recommended small models for this task
# (instruction-following + shell-command generation, ~1-4B, permissive
# license so it can ship with the installer):
#   • Qwen3.5-2B-Instruct   — Apache-2.0, best small coder, ~1.3 GB (Q4)
#   • Phi-4-mini (3.8B)     — MIT, strongest instruction/function-calling
#   • Gemma 4 E2B           — Apache-2.0, smallest/fastest, <1.5 GB
# Example (Ollama):
#   provider = "openai"
#   base_url = "http://localhost:11434/v1"
#   model    = "qwen3.5:2b"
#   api_key  = "ollama"

[assistant]
# Kai — the voice assistant. When enabled, a SECOND hotkey (below) takes a
# spoken query and routes it by WHERE YOU ARE:
#   • focused on a terminal  -> it turns your words into a command, types it
#     at the prompt, and NEVER presses Enter (that stays yours);
#   • anywhere else          -> it answers / searches the web, spoken back.
# Voice in, voice or a drafted command out — you never type to it (typed
# interaction is a future Seneschal-computer thing). On by default: it's
# push-to-talk, so nothing is captured until you press the hotkey or click
# the on-screen orb — the hotkey stays the hard mute.
enabled = true
# What the mind calls itself — the local brain's persona and the on-screen
# copy. "Kai", from KairOS. (The spoken voice agent introduces itself with
# whatever name you gave it in the xAI Voice Agent Builder console.)
name = "Kai"
# xAI Voice Agent Builder id for the realtime voice brain; key falls back
# to providers.xai. Leave empty to use the local [llm] brain only.
agent_id = ""
api_key = ""
# Which brain answers a SPOKEN turn: realtime | local | auto. The xAI voice
# agent is voice-to-voice — it answers your captured audio with speech; the
# terminal route always uses the local [llm] to compile a command. auto =
# the voice agent for spoken answers when configured, local otherwise.
# (`voice-keyboard summon` toggles a turn from the CLI, same as the hotkey.)
brain = "auto"
# The summon binding (a second global binding; dictation keeps Ctrl+Alt+V).
# Default is a BARE modifier — hold Right Ctrl to talk — because a modifier
# alone never reaches the focused app. Held symbol chords (e.g.
# "control+alt+.") work too, but terminals encode them as escape codes
# (CSI-u), so holding one at a shell prompt sprays junk like `6;7u6;7u`.
# While a bare-key gesture is active, pressing any OTHER key aborts it, so
# real Right-Ctrl shortcuts still work. Restart to change — it owns a
# listener.
hotkey = "rightctrl"
# How the summon key behaves, like [hotkey].mode:
#   auto   = HOLD to talk / release to send (walkie-talkie), or a quick TAP
#            to toggle; a tap while Kai is answering cuts her off (barge-in).
#   hold   = hold to talk only.  toggle = tap to start / tap to stop.
mode = "auto"
# A short offline tone when Kai starts listening / captures your question —
# eyes-free confirmation. No network, no audio file. Set false for silence.
earcon = true
# Draw an always-on clickable Kai orb on screen (the GNOME overlay extension
# renders it, bottom-right); click it to summon. Set false to hide it.
button = true
# On Wayland the daemon often can't see the focused app (GPU terminals like
# Ghostty/kitty expose no AT-SPI, and GNOME denies window introspection).
# When focus is UNKNOWN, still attempt the terminal command route — the
# classifier answers questions and only types actual commands (never Enter).
# Set false to always answer by voice when focus can't be resolved.
terminal_fallback = true
# local = never send file contents to the brain; cloud = send excerpts of
# files you explicitly name. Your selection and memory are always allowed.
privacy_mode = "local"
memory_enabled = true
web_enabled = true
max_memory_results = 5
# (Reserved) the terminal route ALWAYS drafts a command (typed, no Enter);
# this would additionally let the brain draft one when you are NOT in a
# terminal. Off by default; unused by the current voice flow.
can_act = false
# Confine any file context the brain may read to this root (default: home).
home_root = ""

[ask]
# Talk to any app: "vk, ask why does this fail" answers about the
# PRIMARY SELECTION through [llm]. mode "say" speaks the answer via TTS;
# "type" types it at the caret (newline-suppressed). This gates only the
# voice trigger; `voice-keyboard ask "…"` is always available.
enabled = false
verbs = ["ask", "explain", "answer"]
mode = "say"

[recall]
# Total recall: search everything you dictated ([flow] history ledger).
# Keyword search needs no setup; set base_url + model to an
# OpenAI-compatible /embeddings endpoint for semantic search — a local
# Ollama works: base_url = "http://localhost:11434/v1",
# model = "nomic-embed-text". Voice trigger gated here;
# `voice-keyboard find "…"` is always available.
enabled = false
verbs = ["recall", "remember"]
mode = "say"
base_url = ""
model = ""
api_key = ""

[remote_mic]
# EXPERIMENTAL multiplayer keyboard: the daemon serves a one-page LAN
# mic over self-signed HTTPS. Open https://<this-machine>:<port>/?t=<token>
# on your phone (accept the certificate warning once), tap start, and
# dictation lands on this desktop. Audio never leaves your network.
# The token is auto-generated and logged at startup when left empty.
# Restart the daemon to toggle — it owns a listening socket.
enabled = false
port = 9177
token = ""

[ambient]
# EXPERIMENTAL containment for long-open sessions: when on, only
# utterances that START with the address word are typed ("vk write
# ..."); room speech never reaches the engine and evaporates. Does NOT
# start background capture — sessions still begin explicitly, and the
# hotkey stays the hard mute.
enabled = false
# Defaults to flow.wake_word when empty.
address_word = ""

[intent]
# The voice→command channel: "vk, run …" compiles ONE command line
# through [llm], types it at the caret, and NEVER presses Enter — the
# refusal is enforced inside the keystroke injector, so nothing the model
# says can execute anything. You review the line and press Enter yourself.
# This switch gates only the voice trigger; `voice-keyboard intent "…"`
# is explicit and always available.
enabled = false
# The instruction's first word that routes to the intent channel.
verbs = ["run", "command", "execute"]

[wake]
# Summon Kai hands-free by saying her name. A tiny LOCAL openWakeWord model
# scores a rolling mic buffer — no transcription, nothing leaves the box —
# and only when it fires does normal capture begin. OFF by default: this is
# the ONE summon path that keeps the mic warm, so the hotkey stays the hard
# mute unless you arm this. Needs the optional dep:
#   pip install 'hyperfurion-vk[wake]'
enabled = false
engine = "openwakeword"
word = "kai"
# Path to a trained "Kai" openWakeWord model. Empty = openWakeWord's bundled
# words (for testing only); train a real one with:
#   python scripts/train_kai_wakeword.py
model_path = ""
# Detection confidence (0..1) required to fire, and a re-fire cooldown.
threshold = 0.5
cooldown_s = 2.0
# Input device for the wake detector; empty = system default.
mic_device = ""

[daemon]
# Defaults to ~/.config/voice-keyboard/socket if unset.
# socket_path = "/run/user/1000/voice-keyboard.sock"
